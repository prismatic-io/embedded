{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "root": false,
  "extends": "//",
  "linter": {
    "rules": {
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off"
      },
      "complexity": {
        "noBannedTypes": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "performance": {
        "noImgElement": "off"
      }
    }
  }
}
