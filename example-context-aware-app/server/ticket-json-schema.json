{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "ticketId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    }
  },
  "required": ["ticketId", "title", "priority"]
}
