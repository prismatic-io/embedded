{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "lib": ["es2020", "DOM"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist/generators",
    "rootDir": "./src/generators",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "target": "es2020",
    "types": ["node"]
  },
  "include": ["src/generators"]
}
